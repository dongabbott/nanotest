# Application
APP_NAME=AI Mobile Test Platform
APP_VERSION=1.0.0
DEBUG=true
ENVIRONMENT=development

# API
API_V1_PREFIX=/api/v1

# Security
SECRET_KEY=your-super-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ALGORITHM=HS256

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/nanotest
DATABASE_ECHO=false

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Object Storage (Aliyun OSS)
OSS_STS_TOKEN_URL=

# Appium
APPIUM_SERVER_URL=http://localhost:4723
APPIUM_SESSION_TIMEOUT=300

# AI/LLM
# 可选值: doubao | qwen
LLM_PROVIDER=doubao

# --- 火山豆包 / Doubao ---
DOUBAO_API_KEY=your-doubao-api-key
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_CHAT_MODEL=doubao-seed-2-0-pro-260215
DOUBAO_EMBEDDING_MODEL=doubao-embedding-vision-251215

# --- 阿里千问 / Qwen ---
QWEN_API_KEY=your-qwen-api-key
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_CHAT_MODEL=qwen-plus
QWEN_EMBEDDING_MODEL=text-embedding-v3

AI_ANALYSIS_TIMEOUT=60

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
